# === X (Twitter) API ===
# Only Bearer Token needed (read-only, no posting)
X_BEARER_TOKEN=your_bearer_token_here

# === Telegram Bot ===
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID: can be a group (-123456789) or channel (@channelname) or user ID
TELEGRAM_CHAT_ID=your_chat_id_here

# === Search Settings ===
# How often to search (minutes). Higher = fewer API calls = lower cost
# Default 60 = ~7,200 reads/month (Basic tier allows 10,000)
SEARCH_INTERVAL_MINUTES=60

# Minimum engagement to filter trending posts
MIN_LIKES=100
MIN_RETWEETS=20

# Results per search (10-100). Lower = fewer API reads
MAX_RESULTS=10
